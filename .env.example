# ============================================================
# .env.example — aiwrite-base environment variable reference
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Rules:
#   - NEVER commit .env to version control.
#   - All values shown here are safe defaults for local development.
#   - Variables marked [REQUIRED IN PRODUCTION] have no safe default
#     and MUST be changed before deploying.
# ============================================================


# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────

# Environment mode. Use "production" in deployed environments.
NODE_ENV="development"

# Host port the Next.js container binds to (docker-compose.yml only).
APP_PORT=3000

# Public base URL of the application. Used by Next.js for metadata, redirects,
# and any absolute URL construction (SSR). Change to your actual domain in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ─────────────────────────────────────────────
# Database (PostgreSQL 16)
# ─────────────────────────────────────────────

# Database name created by the postgres Docker container.
POSTGRES_DB="aiwrite"

# PostgreSQL superuser for the aiwrite database.
POSTGRES_USER="aiwrite"

# [REQUIRED IN PRODUCTION] Strong random password.
# Generate one: openssl rand -base64 32
POSTGRES_PASSWORD="aiwrite_dev_password"

# Host port the postgres container exposes (docker-compose.dev.yml).
# Not exposed in docker-compose.yml (production) — internal access only.
POSTGRES_PORT=5432

# Full connection string used by Prisma (and any direct DB clients).
#
# For LOCAL DEVELOPMENT (npm run dev on host):
#   Host is localhost because postgres runs in Docker with port exposed.
#
# For DOCKER COMPOSE (all services in containers):
#   Replace "localhost" with "postgres" (the Docker service name).
#   docker-compose.yml sets this automatically — do not change it there.
DATABASE_URL="postgresql://aiwrite:aiwrite_dev_password@localhost:5432/aiwrite?schema=app"


# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────

# [REQUIRED IN PRODUCTION] Random secret used to sign JWT tokens.
# Must be at least 32 characters. Changing this invalidates all active sessions.
# Generate one: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_IN_PRODUCTION_use_openssl_rand_base64_64"

# Token lifetime. Accepts values like: 15m, 1h, 7d, 30d.
JWT_EXPIRES_IN="7d"


# ─────────────────────────────────────────────
# MinIO (S3-compatible object storage)
# ─────────────────────────────────────────────

# Hostname for MinIO API connections.
#   Local development (npm run dev): localhost
#   Docker compose (service-to-service): "minio" (set automatically in docker-compose.yml)
MINIO_ENDPOINT="localhost"

# MinIO API port (matches the container port mapping).
MINIO_PORT="9000"

# [REQUIRED IN PRODUCTION] MinIO root credentials.
# Must be changed from the defaults before any public-facing deployment.
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"

# Name of the bucket where uploaded files are stored.
# The application creates this bucket automatically if it does not exist.
MINIO_BUCKET="aiwrite"

# Set to "true" only if MinIO is behind TLS (e.g., behind a reverse proxy with HTTPS).
MINIO_USE_SSL="false"
